<!DOCTYPE html>
<html lang="ru">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>
      <%= title || 'Админ-панель' %> | СпецСинтез
   </title>
   <link rel="stylesheet" href="/admin/css/admin.css">
</head>

<body>
   <div class="admin-wrapper">
      <aside class="admin-sidebar">
         <div class="logo">СпецСинтез Админ</div>
         <nav>
            <ul>
               <li><a href="/admin" class="<%= currentSection === 'dashboard' ? 'active' : '' %>">📊 Главная</a></li>
               <li><a href="/admin/news" class="<%= currentSection === 'news' ? 'active' : '' %>">📰 Новости</a></li>
               <li><a href="/admin/categories" class="<%= currentSection === 'categories' ? 'active' : '' %>">🗂️
                     Категории</a></li>
               <li><a href="/admin/products" class="<%= currentSection === 'products' ? 'active' : '' %>">📦 Товары</a>
               </li>
               <li><a href="/admin/package-types" class="<%= currentSection === 'package-types' ? 'active' : '' %>">🏷️
                     Типы упаковок</a></li>
               <li><a href="/" target="_blank">🌐 На сайт</a></li>
               <li><a href="/admin/logout" id="logout-link">🚪 Выйти</a></li>
            </ul>
         </nav>
      </aside>
      <main class="admin-content">
         <% if (typeof successMessage !=='undefined' && successMessage) { %>
            <div class="alert alert-success">
               <%= successMessage %>
            </div>
            <% } %>
               <% if (typeof errorMessage !=='undefined' && errorMessage) { %>
                  <div class="alert alert-error">
                     <%= errorMessage %>
                  </div>
                  <% } %>
                     <%- body %>
      </main>
   </div>
   <script nonce="<%= nonce %>">
      document.addEventListener('DOMContentLoaded', function () {
         // Подтверждение выхода
         document.getElementById('logout-link').addEventListener('click', function (e) {
            if (!confirm('Выйти из админ-панели?')) e.preventDefault();
         });

         // Подтверждение удаления для всех форм с action="/admin/.../delete"
         document.querySelectorAll('form[action*="/delete"]').forEach(form => {
            form.addEventListener('submit', function (e) {
               if (!confirm('Вы уверены, что хотите удалить?')) e.preventDefault();
            });
         });
      });
   </script>
   
</body>

</html>