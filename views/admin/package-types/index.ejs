<h1>Типы упаковок</h1>
<a href="/admin/package-types/create" class="btn">+ Создать тип упаковки</a>
<table class="data-table">
   <thead>
      <tr>
         <th>ID</th>
         <th>Название</th>
         <th>Иконка</th>
         <th>Действия</th>
      </tr>
   </thead>
   <tbody>
      <% types.forEach(t=> { %>
         <tr>
            <td>
               <%= t.id %>
            </td>
            <td>
               <%= t.name %>
            </td>
            <td>
               <% if (t.icon_url) { %><img src="<%= t.icon_url %>" style="height:30px;">
                  <% } else { %>—<% } %>
            </td>
            <td class="actions">
               <a href="/admin/package-types/<%= t.id %>/edit" class="btn-small">✏️</a>
               <form method="POST" action="/admin/package-types/<%= t.id %>/delete" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn-small btn-danger">🗑️</button>
               </form>
            </td>
         </tr>
         <% }); %>
   </tbody>
</table>