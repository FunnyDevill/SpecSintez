<h1>Товары</h1>
<a href="/admin/products/create" class="btn">+ Создать товар</a>
<table class="data-table">
   <thead>
      <tr>
         <th>ID</th>
         <th>Название</th>
         <th>Slug</th>
         <th>Категория</th>
         <th>Сорт.</th>
         <th>Активен</th>
         <th>Действия</th>
      </tr>
   </thead>
   <tbody>
      <% products.forEach(p=> { %>
         <tr>
            <td>
               <%= p.id %>
            </td>
            <td>
               <%= p.name %>
            </td>
            <td>
               <%= p.slug %>
            </td>
            <td>
               <%= p.category_name || '-' %>
            </td>
            <td>
               <%= p.sort_order %>
            </td>
            <td>
               <%= p.is_active ? '✅' : '❌' %>
            </td>
<td>
   <a href="/admin/products/<%= p.id %>/edit" class="btn-small">✏️ Редактировать</a>
   <form method="POST" action="/admin/products/<%= p.id %>/delete" style="display:inline;" onsubmit="return confirm('Удалить товар?')">
      <button type="submit" class="btn-small btn-danger">🗑️ Удалить</button>
   </form>
</td>
         </tr>
         <% }); %>
   </tbody>
</table>