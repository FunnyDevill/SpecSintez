<h1>Товары</h1>

<!-- Блок поиска и сброса -->
<div class="toolbar">
   <form method="GET" action="/admin/products">
      <input type="text" name="search" value="<%= currentSearch || '' %>" placeholder="Поиск по названию или slug...">
      <button type="submit" class="btn">🔍 Найти</button>
      <% if (currentSearch) { %>
         <a href="/admin/products" class="btn-cancel">✖ Сбросить</a>
      <% } %>
   </form>
   <a href="/admin/products/create" class="btn add-product-btn">+ Создать товар</a>
</div>

<!-- Таблица с сортируемыми заголовками -->
<table class="data-table">
   <thead>
      <tr>
         <th>ID</th>
         <th class="sortable">
            <a href="?search=<%= currentSearch || '' %>&sort=name&order=<%= sortField === 'name' && sortOrder === 'asc' ? 'desc' : 'asc' %>">
               Название
               <%= sortField === 'name' ? (sortOrder === 'asc' ? '▲' : '▼') : '' %>
            </a>
         </th>
         <th class="sortable">
            <a href="?search=<%= currentSearch || '' %>&sort=slug&order=<%= sortField === 'slug' && sortOrder === 'asc' ? 'desc' : 'asc' %>">
               Код для ссылки
               <%= sortField === 'slug' ? (sortOrder === 'asc' ? '▲' : '▼') : '' %>
            </a>
         </th>
         <th>Категория</th>
         <th class="sortable">
            <a href="?search=<%= currentSearch || '' %>&sort=sort_order&order=<%= sortField === 'sort_order' && sortOrder === 'asc' ? 'desc' : 'asc' %>">
               Сорт.
               <%= sortField === 'sort_order' ? (sortOrder === 'asc' ? '▲' : '▼') : '' %>
            </a>
         </th>
         <th>Активен</th>
         <th>Действия</th>
      </tr>
   </thead>
   <tbody>
      <% if (products.length === 0) { %>
         <tr><td colspan="7" style="text-align: center;">Товары не найдены</td></tr>
      <% } else { %>
         <% products.forEach(p => { %>
            <tr>
               <td><%= p.id %></td>
               <td><strong><%= p.name %></strong></td>
               <td><code><%= p.slug %></code></td>
               <td><%= p.category_name || '-' %></td>
               <td><%= p.sort_order %></td>
               <td><%= p.is_active ? '✅' : '❌' %></td>
               <td class="actions">
                  <a href="/admin/products/<%= p.id %>/edit" class="btn-small">✏️</a>
                  <form method="POST" action="/admin/products/<%= p.id %>/delete" class="inline-form">
                     <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                     <button type="submit" class="btn-small btn-danger">🗑️</button>
                  </form>
               </td>
            </tr>
         <% }); %>
      <% } %>
   </tbody>
</table>

<!-- Пагинация -->
<% if (totalPages > 1) { %>
   <div class="pagination">
      <% if (currentPage > 1) { %>
         <a href="?search=<%= currentSearch || '' %>&sort=<%= sortField %>&order=<%= sortOrder %>&page=<%= currentPage - 1 %>" class="btn-small">← Назад</a>
      <% } %>
      <span>Страница <%= currentPage %> из <%= totalPages %></span>
      <% if (currentPage < totalPages) { %>
         <a href="?search=<%= currentSearch || '' %>&sort=<%= sortField %>&order=<%= sortOrder %>&page=<%= currentPage + 1 %>" class="btn-small">Вперёд →</a>
      <% } %>
   </div>
<% } %>