<% if (typeof errors !== 'undefined' && errors.length > 0) { %>
  <div class="form-errors">
    <strong>Ошибки:</strong>
    <ul>
      <% errors.forEach(err => { %>
        <li><%= err %></li>
      <% }); %>
    </ul>
  </div>
<% } %>

<h1><%= product && product.id ? 'Редактирование товара' : 'Создание товара' %></h1>

<form method="POST" action="<%= action %>" id="product-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <!-- Основные данные -->
  <fieldset>
    <legend>Основные данные</legend>
    <div class="form-row two-cols">
      <div class="form-group">
        <label for="name">Название товара *</label>
        <input type="text" id="name" name="name" value="<%= product ? product.name : '' %>" required>
      </div>
      <div class="form-group">
        <label for="slug">Код для ссылки (slug)</label>
        <input type="text" id="slug" name="slug" value="<%= product ? product.slug : '' %>">
        <small>Оставьте пустым для автоматической генерации</small>
      </div>
    </div>

    <div class="form-group">
      <label for="excerpt">Краткое описание (отображается в списках)</label>
      <textarea id="excerpt" name="excerpt" rows="3"><%= product ? product.excerpt : '' %></textarea>
    </div>
  </fieldset>

  <!-- Описание -->
  <fieldset>
    <legend>Описание</legend>
    <div id="tinymce-editor" class="tinymce-container"></div>
    <input type="hidden" name="description" id="description-hidden">
  </fieldset>

  <!-- Свойства -->
  <fieldset>
    <legend>Свойства</legend>
    <div id="tinymce-properties" class="tinymce-container"></div>
    <input type="hidden" name="properties" id="properties-hidden">
  </fieldset>

  <!-- Категории -->
  <fieldset>
    <legend>Категории</legend>
    <div class="form-group">
      <label>Выберите категории (можно несколько)</label>
      <div class="categories-tree" id="categories-tree">
        <%
          function renderTree(items, selected) {
            items.forEach(function(item) {
              var hasChildren = item.children && item.children.length > 0;
              var collapsed = hasChildren && selected.indexOf(item.id) === -1;
        %>
              <li class="tree-node <%= hasChildren ? 'has-children' : '' %> <%= collapsed ? 'collapsed' : '' %>">
                <span class="tree-toggle"><%= hasChildren ? '▶' : '' %></span>
                <label class="category-label">
                  <input type="checkbox" name="categories" value="<%= item.id %>" class="category-checkbox"
                    <%= selected.indexOf(item.id) !== -1 ? 'checked' : '' %>
                    data-parent-id="<%= item.parent_id || '' %>">
                  <%= item.name %>
                </label>
                <% if (hasChildren) { %>
                  <ul>
                    <% renderTree(item.children, selected); %>
                  </ul>
                <% } %>
              </li>
        <%
            });
          }

          var catMap = new Map();
          categories.forEach(function(c) { catMap.set(c.id, Object.assign({}, c, { children: [] })); });
          var roots = [];
          categories.forEach(function(c) {
            if (c.parent_id && catMap.has(c.parent_id)) {
              catMap.get(c.parent_id).children.push(catMap.get(c.id));
            } else if (!c.parent_id) {
              roots.push(catMap.get(c.id));
            }
          });
        %>
        <ul class="tree-root">
          <% renderTree(roots, selectedCategories || []); %>
        </ul>
      </div>
    </div>
  </fieldset>

  <!-- Направления -->
  <fieldset>
    <legend>Направления</legend>
    <div class="directions-list">
      <% (typeof allDirections !== 'undefined' ? allDirections : []).forEach(function(dir) { %>
         <label class="direction-label">
            <input type="checkbox" name="directions" value="<%= dir.id %>"
               <%= (typeof selectedDirections !== 'undefined' && selectedDirections.includes(dir.id)) ? 'checked' : '' %>>
            <span><%= dir.name %></span>
         </label>
      <% }); %>
    </div>
  </fieldset>

  <!-- Типы упаковок -->
  <fieldset>
    <legend>Типы упаковок и объёмы</legend>
    <table class="data-table">
      <thead>
        <tr><th>Выбрать</th><th>Тип упаковки</th><th>Объём</th></tr>
      </thead>
      <tbody>
        <% 
           var selectedMap = {};
           (typeof selectedPackageTypes !== 'undefined' ? selectedPackageTypes : []).forEach(function(s) { selectedMap[s.package_type_id] = s.volume || ''; });
        %>
        <% if (typeof allPackageTypes !== 'undefined') { %>
          <% allPackageTypes.forEach(function(type) { 
              var checked = selectedMap.hasOwnProperty(type.id) ? 'checked' : '';
              var vol = selectedMap[type.id] || '';
              var volName = 'volume_' + type.id;
          %>
            <tr>
              <td><input type="checkbox" name="package_type_ids" value="<%= type.id %>" <%= checked %>></td>
              <td><%= type.name %> <% if (type.icon_url) { %><img src="<%= type.icon_url %>" class="pkg-icon-inline"><% } %></td>
              <td><input type="text" name="<%= volName %>" value="<%= vol %>" placeholder="1 л, 500 мл..." class="volume-input"></td>
            </tr>
          <% }); %>
        <% } %>
      </tbody>
    </table>
  </fieldset>

  <!-- Настройки отображения -->
  <fieldset>
    <legend>Настройки отображения</legend>
    <div class="form-row two-cols">
      <div class="form-group">
        <label for="sort_order">Порядок сортировки</label>
        <input type="number" id="sort_order" name="sort_order" value="<%= product ? product.sort_order : 0 %>">
        <small>Чем меньше число, тем выше в списке</small>
      </div>
      <div class="form-group checkbox-group">
        <label>
          <input type="checkbox" name="is_active" <%= (product && product.is_active) ? 'checked' : '' %>> Товар активен
        </label>
      </div>
    </div>
  </fieldset>

  <div class="form-actions">
    <button type="submit" class="btn">Сохранить</button>
    <a href="/admin/products" class="btn-cancel">Отмена</a>
  </div>
</form>

<% if (product && product.id) { %>
  <hr>
  <div class="images-section">
    <h3>Изображения товара</h3>
    <div class="form-row two-cols images-row">
      <div class="form-group">
        <label>Основное изображение</label>
        <div class="main-image-preview" id="main-image-preview">
          <% if (product.image_url) { %>
            <img src="<%= product.image_url %>" alt="Основное изображение" id="main-image-img">
          <% } else { %>
            <p class="not-selected">Не выбрано</p>
          <% } %>
        </div>
        <small>Нажмите «⭐ Основное» у нужной картинки в галерее</small>
      </div>
      <div class="form-group">
        <label>Галерея изображений</label>
        <div class="image-upload-area" id="gallery-upload-area">
          <input type="file" id="gallery-file-input" accept="image/*" multiple class="hidden">
          <div class="upload-placeholder" id="gallery-placeholder">
            <span>📷</span>
            <p>Перетащите изображения сюда или нажмите для выбора</p>
            <small>Поддерживаются JPG, PNG, WebP</small>
          </div>
        </div>
        <div class="images-grid" id="gallery-grid"></div>
      </div>
    </div>
  </div>
<% } %>

<script src="/tinymce/tinymce.min.js" nonce="<%= nonce %>"></script>
<script src="/js/admin-slugify.js" nonce="<%= nonce %>"></script>

<script nonce="<%= nonce %>">
  document.addEventListener('DOMContentLoaded', function () {
    tinymce.init({
      license_key: 'gpl',
      selector: '#tinymce-editor',
      base_url: '/tinymce',
      height: 400,
      menubar: false,
      plugins: 'lists code',
      toolbar: 'bold italic underline | bullist numlist | removeformat | code',
      content_css: ['/css/main.css', '/css/tinymce-content.css'],
      promotion: false,
      setup: function (editor) {
        var existingHtml = <%- safeJson(product ? product.description : null) %>;
        if (existingHtml && existingHtml !== '""' && existingHtml !== '') {
          editor.on('init', function () {
            editor.setContent(existingHtml);
          });
        }

        var form = document.getElementById('product-form');
        var hiddenField = document.getElementById('description-hidden');
        form.addEventListener('submit', function () {
          hiddenField.value = editor.getContent();
        });
      }
    });

    tinymce.init({
      license_key: 'gpl',
      selector: '#tinymce-properties',
      base_url: '/tinymce',
      height: 400,
      menubar: false,
      plugins: 'lists code',
      toolbar: 'bold italic underline | bullist numlist | removeformat | code',
      content_css: ['/css/main.css', '/css/tinymce-content.css'],
      promotion: false,
      setup: function (editor) {
        var existingProperties = <%- safeJson(product ? product.properties : null) %>;
        if (existingProperties && existingProperties !== '""' && existingProperties !== '') {
          editor.on('init', function () {
            editor.setContent(existingProperties);
          });
        }

        var form = document.getElementById('product-form');
        var hiddenProperties = document.getElementById('properties-hidden');
        form.addEventListener('submit', function () {
          hiddenProperties.value = editor.getContent();
        });
      }
    });

    AppSlugify.bindToFields('name', 'slug');

    initCategoryTree();

    var productId = <%= product && product.id ? product.id : 'null' %>;
    if (productId !== null && productId !== 'null') {
      loadGallery();
      initGalleryUpload();
    }

    function initGalleryUpload() {
      var uploadArea = document.getElementById('gallery-upload-area');
      var fileInput = document.getElementById('gallery-file-input');
      if (!uploadArea || !fileInput) return;

      uploadArea.addEventListener('click', function() { fileInput.click(); });
      
      fileInput.addEventListener('change', function() {
        if (fileInput.files.length > 0) uploadFiles(fileInput.files);
      });

      uploadArea.addEventListener('dragover', function(e) {
        e.preventDefault(); 
        uploadArea.classList.add('dragover');
      });
      
      uploadArea.addEventListener('dragleave', function() {
        uploadArea.classList.remove('dragover');
      });
      
      uploadArea.addEventListener('drop', function(e) {
        e.preventDefault(); 
        uploadArea.classList.remove('dragover');
        if (e.dataTransfer.files.length > 0) uploadFiles(e.dataTransfer.files);
      });
    }

    function loadGallery() {
      fetch('/admin/products/' + productId + '/images/list')
        .then(function(res) { return res.json(); })
        .then(function(images) {
          renderGallery(images);
          var mainImg = images.find(function(img) { return img.is_main; });
          updateMainPreview(mainImg ? mainImg.image_url : null);
        })
        .catch(function(err) { console.error('Ошибка загрузки галереи:', err); });
    }

    function renderGallery(images) {
      var grid = document.getElementById('gallery-grid');
      if (!grid) return;
      
      grid.innerHTML = images.map(function(img) {
        return '<div class="image-card" data-id="' + img.id + '">' +
          '<img src="' + img.image_url + '" alt="Изображение">' +
          '<div class="actions">' +
            '<button type="button" class="btn-small set-main-btn" data-id="' + img.id + '">⭐ Основное</button>' +
            '<button type="button" class="btn-small btn-danger delete-img-btn" data-id="' + img.id + '">🗑️</button>' +
          '</div>' +
        '</div>';
      }).join('');

      grid.querySelectorAll('.set-main-btn').forEach(function(btn) {
        btn.addEventListener('click', function() { setMainImage(btn.dataset.id); });
      });
      
      grid.querySelectorAll('.delete-img-btn').forEach(function(btn) {
        btn.addEventListener('click', function() { deleteImage(btn.dataset.id); });
      });
    }

    var csrfToken = document.querySelector('input[name="_csrf"]').value;

    function uploadFiles(files) {
      var formData = new FormData();
      for (var i = 0; i < files.length; i++) {
        formData.append('images', files[i]);
      }
      fetch('/admin/products/' + productId + '/images/upload', {
        method: 'POST',
        headers: { 'X-CSRF-Token': csrfToken },
        body: formData
      })
      .then(function(res) { if (!res.ok) throw new Error('Ошибка'); loadGallery(); })
      .catch(function(err) { alert('Не удалось загрузить изображения'); console.error(err); })
      .finally(function() {
        document.getElementById('gallery-file-input').value = '';
      });
    }

    function setMainImage(imageId) {
      fetch('/admin/products/' + productId + '/images/' + imageId + '/set-main', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrfToken },
        body: '_csrf=' + encodeURIComponent(csrfToken)
      })
      .then(function(res) { if (!res.ok) throw new Error('Ошибка'); loadGallery(); })
      .catch(function(err) { alert('Ошибка установки главного изображения'); console.error(err); });
    }

    function deleteImage(imageId) {
      if (!confirm('Удалить изображение?')) return;
      fetch('/admin/products/' + productId + '/images/' + imageId + '/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-CSRF-Token': csrfToken },
        body: '_csrf=' + encodeURIComponent(csrfToken)
      })
      .then(function(res) { if (!res.ok) throw new Error('Ошибка'); loadGallery(); })
      .catch(function(err) { alert('Ошибка удаления'); console.error(err); });
    }

    function updateMainPreview(imageUrl) {
      var previewDiv = document.getElementById('main-image-preview');
      if (!previewDiv) return;
      if (imageUrl) {
        previewDiv.innerHTML = '<img src="' + imageUrl + '" alt="Основное изображение" id="main-image-img">';
      } else {
        previewDiv.innerHTML = '<p class="not-selected">Не выбрано</p>';
      }
    }
  });

  function initCategoryTree() {
    var tree = document.getElementById('categories-tree');
    if (!tree) return;

    tree.addEventListener('click', function (e) {
      var toggle = e.target.closest('.tree-toggle');
      if (!toggle) return;
      var li = toggle.closest('li');
      if (!li) return;
      li.classList.toggle('collapsed');
      var ul = li.querySelector(':scope > ul');
      if (ul) ul.style.display = li.classList.contains('collapsed') ? 'none' : 'block';
    });

    var allCheckboxes = tree.querySelectorAll('input[type="checkbox"][name="categories"]');
    allCheckboxes.forEach(function(cb) {
      cb.addEventListener('change', function () {
        var isChecked = this.checked;
        var li = this.closest('li');
        var parentLi = li.parentElement.closest('li');

        if (isChecked && parentLi) {
          var currentParent = parentLi;
          while (currentParent) {
            var parentCb = currentParent.querySelector(':scope > label > input[type="checkbox"]');
            if (parentCb && !parentCb.checked) parentCb.checked = true;
            currentParent = currentParent.parentElement.closest('li');
          }
        } else if (!isChecked) {
          var descendantCbs = li.querySelectorAll('ul input[type="checkbox"]');
          descendantCbs.forEach(function(dcb) { dcb.checked = false; });
        }
      });
    });
  }
</script>