<h1>Изображения товара: <%= product.name %>
</h1>
<a href="/admin/products" class="btn">← Назад к товарам</a>

<h2>Загрузить новые изображения</h2>
<form method="POST" action="/admin/products/<%= product.id %>/upload-images" enctype="multipart/form-data">
   <input type="file" name="images" multiple accept="image/*" required>
   <button type="submit" class="btn">Загрузить</button>
</form>

<h2>Существующие изображения</h2>
<div class="images-grid">
   <% images.forEach(img=> { %>
      <div class="image-card">
         <img src="<%= img.image_url %>" alt="Preview">
         <p>ID: <%= img.id %>
         </p>
         <p>Главное: <%= img.is_main ? '✅' : '❌' %>
         </p>
         <p>Тип упаковки: <%= img.package_name || '—' %>
         </p>
         <div class="actions">
            <% if (!img.is_main) { %>
               <form method="POST" action="/admin/products/<%= product.id %>/images/<%= img.id %>/set-main"
                  style="display:inline;">
                  <button type="submit" class="btn-small">⭐ Сделать главным</button>
               </form>
               <% } %>
                  <form method="POST" action="/admin/products/<%= product.id %>/images/<%= img.id %>/delete"
                     style="display:inline;" onsubmit="return confirm('Удалить изображение?')">
                     <button type="submit" class="btn-small btn-danger">🗑️ Удалить</button>
                  </form>
         </div>
      </div>
      <% }); %>
</div>