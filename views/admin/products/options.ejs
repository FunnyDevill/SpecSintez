<h1>Опции товара: <%= product.name %>
</h1>
<a href="/admin/products" class="btn">← Назад к товарам</a>

<h2>Добавить опцию</h2>
<form method="POST" action="/admin/products/<%= product.id %>/options" enctype="multipart/form-data">
   <label>Название (например, 1л, 5л, 200мл)</label>
   <input type="text" name="name" required>
   <label>Иконка (изображение)</label>
   <input type="file" name="image" accept="image/*">
   <button type="submit" class="btn">Добавить</button>
</form>

<h2>Список опций</h2>
<table class="data-table">
   <thead>
      <tr>
         <th>ID</th>
         <th>Название</th>
         <th>Иконка</th>
         <th>Действия</th>
      </tr>
   </thead>
   <tbody>
      <% options.forEach(opt=> { %>
         <tr>
            <td>
               <%= opt.id %>
            </td>
            <td>
               <%= opt.name %>
            </td>
            <td>
               <% if (opt.image_url) { %><img src="<%= opt.image_url %>" style="height:40px;">
                  <% } else { %>—<% } %>
            </td>
            <td>
               <form method="POST" action="/admin/products/<%= product.id %>/options/<%= opt.id %>/edit"
                  enctype="multipart/form-data" style="display:inline-block;">
                  <input type="text" name="name" value="<%= opt.name %>" required style="width:120px;">
                  <input type="file" name="image" accept="image/*">
                  <button type="submit" class="btn-small">✏️ Обновить</button>
               </form>
               <form method="POST" action="/admin/products/<%= product.id %>/options/<%= opt.id %>/delete"
                  style="display:inline;" onsubmit="return confirm('Удалить опцию?')">
                  <button type="submit" class="btn-small btn-danger">🗑️</button>
               </form>
            </td>
         </tr>
         <% }); %>
   </tbody>
</table>