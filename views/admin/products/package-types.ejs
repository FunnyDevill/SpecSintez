<h1>Типы упаковок для товара: <%= product.name %></h1>
<a href="/admin/products/<%= product.id %>/edit" class="btn">← Назад к редактированию</a>

<form method="POST" action="/admin/products/<%= product.id %>/package-types">
    <p>Выберите типы упаковок и укажите объём (например, "5 л", "200 мл"):</p>
    <table class="data-table">
        <thead>
            <tr><th>Выбрать</th><th>Тип упаковки</th><th>Объём</th></tr>
        </thead>
        <tbody>
            <% 
               const selectedMap = {};
               (selected || []).forEach(s => { selectedMap[s.package_type_id] = { volume: s.volume || '' }; });
            %>
            <% allTypes.forEach(type => { 
                const checked = selectedMap[type.id] ? 'checked' : '';
                const volumeValue = selectedMap[type.id] ? selectedMap[type.id].volume : '';
                const volumeFieldName = `volume_${type.id}`;
            %>
                <tr>
                    <td><input type="checkbox" name="package_type_ids" value="<%= type.id %>" <%= checked %>></td>
                    <td><%= type.name %> <% if (type.icon_url) { %>(<img src="<%= type.icon_url %>" style="height:20px;">)<% } %></td>
                    <td><input type="text" name="<%= volumeFieldName %>" value="<%= volumeValue %>" placeholder="1 л, 500 мл..." style="width:120px;"></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
    <button type="submit" class="btn">Сохранить</button>
</form>