<% if (typeof errors !=='undefined' && errors.length> 0) { %>
   <div class="form-errors">
      <strong>Ошибки:</strong>
      <ul>
         <% errors.forEach(err=> { %>
            <li>
               <%= err %>
            </li>
            <% }); %>
      </ul>
   </div>
   <% } %>

      <h1>
         <%= news ? 'Редактирование новости' : 'Создание новости' %>
      </h1>

      <form method="POST" action="<%= action %>" enctype="multipart/form-data" id="news-form">
         <input type="hidden" name="_csrf" value="<%= csrfToken %>">

         <fieldset>
            <legend>Основные данные</legend>
            <div class="form-row two-cols">
               <div class="form-group">
                  <label for="title">Заголовок *</label>
                  <input type="text" id="title" name="title" value="<%= news ? news.title : '' %>" required>
               </div>
               <div class="form-group">
                  <label for="slug">Код для ссылки (slug) *</label>
                  <input type="text" id="slug" name="slug" value="<%= news ? news.slug : '' %>">
                  <small>Оставьте пустым для автоматической генерации из названия</small>
               </div>
            </div>

            <div class="form-group">
               <label for="excerpt">Краткое описание (excerpt)</label>
               <textarea id="excerpt" name="excerpt" rows="3"><%= news ? news.excerpt : '' %></textarea>
            </div>
         </fieldset>

         <fieldset>
            <legend>Полный текст</legend>
            <div id="tinymce-editor" class="tinymce-container"></div>
            <input type="hidden" name="content" id="content-hidden">
         </fieldset>

         <fieldset>
            <legend>Изображение</legend>
            <div class="form-group">
               <label>Изображение новости</label>
               <% if (news && news.image_url) { %>
                  <div class="current-image-block mb-10">
                     <img src="<%= news.image_url %>" alt="Текущее изображение" id="current-image-img"
                        class="news-image-preview">
                     <button type="button" id="remove-image-btn" class="btn-small btn-danger ml-10">✖ Удалить
                        изображение</button>
                     <input type="hidden" name="remove_image" id="remove-image-flag" value="false">
                  </div>
                  <% } %>

                     <div class="image-upload-area" id="image-upload-area">
                        <input type="file" name="image" id="image-file-input" accept="image/*" class="hidden">
                        <div class="upload-placeholder" id="image-placeholder">
                           <span>📷</span>
                           <p>Перетащите изображение сюда или нажмите для выбора</p>
                           <small>Поддерживаются JPG, PNG, WebP</small>
                        </div>
                        <img id="image-preview" class="image-preview hidden" src="" alt="Предпросмотр">
                     </div>
                     <small>Загрузите новое изображение или оставьте текущее.</small>
            </div>
         </fieldset>

         <fieldset>
            <legend>Публикация</legend>
            <div class="form-row two-cols">
               <div class="form-group">
                  <label for="published_at">Дата публикации *</label>
                  <input type="date" id="published_at" name="published_at" required
                     value="<%= news && news.published_at ? new Date(news.published_at).toISOString().slice(0,10) : '' %>">
                  <small>Обязательное поле</small>
               </div>
            </div>
            <div class="form-group checkbox-group">
               <label>
                  <input type="checkbox" name="is_active" <%=news && news.is_active ? 'checked' : '' %>> Активна
               </label>
            </div>
            <div class="form-group checkbox-group">
               <label>
                  <input type="checkbox" name="is_hero" <%=news && news.is_hero ? 'checked' : '' %>> Hero (главная
                  новость)
               </label>
            </div>
         </fieldset>

         <fieldset>
            <legend>SEO</legend>
            <div class="form-group">
               <label for="meta_title">Meta Title</label>
               <input type="text" id="meta_title" name="meta_title" value="<%= news ? news.meta_title : '' %>">
            </div>
            <div class="form-group">
               <label for="meta_description">Meta Description</label>
               <textarea id="meta_description" name="meta_description"
                  rows="2"><%= news ? news.meta_description : '' %></textarea>
            </div>
         </fieldset>

         <div class="form-actions">
            <button type="submit" class="btn">Сохранить</button>
            <a href="/admin/news" class="btn-cancel">Отмена</a>
         </div>
      </form>

      <script src="/tinymce/tinymce.min.js" nonce="<%= nonce %>"></script>
      <script src="/js/admin-slugify.js" nonce="<%= nonce %>"></script>

      <script nonce="<%= nonce %>">
         document.addEventListener('DOMContentLoaded', function () {
            tinymce.init({
               license_key: 'gpl',
               selector: '#tinymce-editor',
               base_url: '/tinymce',
               height: 400,
               menubar: false,
               plugins: 'lists code',
               toolbar: 'bold italic underline | bullist numlist | removeformat | code',
               content_css: ['/css/main.css', '/css/tinymce-content.css'],
               promotion: false,
               setup: function (editor) {
                  <% if (news && news.content) { %>
                  var existingContent = <%- JSON.stringify(news.content) %>;
                  <% } else { %>
                  var existingContent = '';
                  <% } %>
                  
                  if (existingContent) {
                     editor.on('init', function () {
                        editor.setContent(existingContent);
                     });
                  }

                  var form = document.getElementById('news-form');
                  var hiddenContent = document.getElementById('content-hidden');
                  form.addEventListener('submit', function () {
                     hiddenContent.value = editor.getContent();
                  });
               }
            });

            AppSlugify.bindToFields('title', 'slug');

            var uploadArea = document.getElementById('image-upload-area');
            var fileInput = document.getElementById('image-file-input');
            var placeholder = document.getElementById('image-placeholder');
            var newPreview = document.getElementById('image-preview');
            var currentImg = document.getElementById('current-image-img');
            var removeBtn = document.getElementById('remove-image-btn');
            var removeFlag = document.getElementById('remove-image-flag');

            if (uploadArea) {
               uploadArea.addEventListener('click', function (e) {
                  if (e.target !== removeBtn) fileInput.click();
               });

               fileInput.addEventListener('change', function () {
                  if (fileInput.files.length > 0) handleFile(fileInput.files[0]);
               });

               uploadArea.addEventListener('dragover', function (e) { 
                  e.preventDefault(); 
                  uploadArea.classList.add('dragover'); 
               });
               
               uploadArea.addEventListener('dragleave', function () { 
                  uploadArea.classList.remove('dragover'); 
               });
               
               uploadArea.addEventListener('drop', function (e) {
                  e.preventDefault();
                  uploadArea.classList.remove('dragover');
                  if (e.dataTransfer.files.length > 0) handleFile(e.dataTransfer.files[0]);
               });
            }

            function handleFile(file) {
               if (!file || !file.type.startsWith('image/')) {
                  alert('Пожалуйста, выберите изображение');
                  return;
               }
               var reader = new FileReader();
               reader.onload = function (e) {
                  newPreview.src = e.target.result;
                  newPreview.classList.remove('hidden');
                  placeholder.classList.add('hidden');
                  if (removeBtn) {
                     removeBtn.classList.add('hidden');
                     removeFlag.value = 'false';
                  }
                  if (currentImg) currentImg.classList.add('hidden');
               };
               reader.readAsDataURL(file);
            }

            if (removeBtn) {
               removeBtn.addEventListener('click', function () {
                  if (currentImg) currentImg.classList.add('hidden');
                  removeBtn.classList.add('hidden');
                  removeFlag.value = 'true';
               });
            }

            var form = document.getElementById('news-form');
            if (form) {
               form.addEventListener('submit', function(e) {
                  var dateInput = document.getElementById('published_at');
                  if (!dateInput.value) {
                     e.preventDefault();
                     alert('Пожалуйста, укажите дату публикации');
                     dateInput.focus();
                     dateInput.style.borderColor = '#e74c3c';
                     return false;
                  }
                  dateInput.style.borderColor = '';
               });
            }
         });
      </script>